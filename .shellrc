#!/usr/bin/env bash

# Load the shell dotfiles, and then some:
# ~/.path can be used to extend `$PATH`
for file in ~/.{path,exports,aliases}; do
  [ -r "$file" ] && [ -f "$file" ] && source "$file"
done
unset file

if command -v goenv &> /dev/null; then
  export PATH="$GOENV_ROOT/shims:$PATH"
  eval "$(goenv init -)"
fi

if ! command -v uv &> /dev/null && command -v pyenv &> /dev/null; then
  eval "$(pyenv init -)"
  if pyenv commands | grep virtualenv-init &> /dev/null; then
    eval "$(pyenv virtualenv-init -)"
  fi
fi

if command -v rustup &> /dev/null && command -v brew &> /dev/null; then
  _rustup_prefix="$(brew --prefix rustup 2>/dev/null)"
  [ -x "$_rustup_prefix/bin/rustup" ] && export PATH="$_rustup_prefix/bin:$PATH"
  unset _rustup_prefix
fi

[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

[ -s "$SDKMAN_DIR/bin/sdkman-init.sh" ] && source "$SDKMAN_DIR/bin/sdkman-init.sh"

# ~/.extra can be used for other settings you don’t want to commit
[ -r "$HOME/.extra" ] && [ -f "$HOME/.extra" ] && source "$HOME/.extra"
